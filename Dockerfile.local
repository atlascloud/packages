FROM golang:alpine

RUN apk add --no-cache git gcc musl-dev abuild

#checkov:skip=CKV_DOCKER_3: this is a local dev file
# USER 1000:1000

RUN go install github.com/githubnemo/CompileDaemon@latest

WORKDIR /app
COPY . .

RUN go mod download

HEALTHCHECK --interval=5m --timeout=10s \
    CMD curl -fs localhost:8888/health/ready

ENTRYPOINT CompileDaemon \
    -build="go build -buildvcs=false ./cmd/api" \
    -color=true \
    -graceful-kill=true \
    -log-prefix=false \
    -command=./api
